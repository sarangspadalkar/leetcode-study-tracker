{
    "arrowParens": "always",
    "bracketSameLine": false,
    "bracketSpacing": false,
    "endOfLine": "lf",
    "htmlWhitespaceSensitivity": "ignore",
    "plugins": ["prettier-plugin-organize-imports"],
    "printWidth": 100,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all"
}
